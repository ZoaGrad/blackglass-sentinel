# Blackglass Sentinel — Environment Configuration
# Blackglass Continuum LLC // CAGE: 17TJ5
# Copy to .env and fill in real values. NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# Observability (required)
# ---------------------------------------------------------------------------
HONEYCOMB_API_KEY=

# ---------------------------------------------------------------------------
# LLM / Safety Gasket (optional — needed for stream_safe_analysis)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# A.I.R. VaultNode — Variance Core telemetry (required for get_vault_variance)
# ---------------------------------------------------------------------------
# Must match the value set in air-node/.env and blackglass-variance-core/.env.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AIR_NODE_URL=http://localhost:8000
AIR_NODE_API_KEY=

# ---------------------------------------------------------------------------
# GOD_MODE override (CM-6 compliant — explicit env flag, audit-logged)
# ---------------------------------------------------------------------------
# Set SENTINEL_GOD_MODE=true to lock clock to SENTINEL_GOD_HOUR.
# Use for demos/debug ONLY. MUST be false before federal deployment.
SENTINEL_GOD_MODE=false
SENTINEL_GOD_HOUR=3
